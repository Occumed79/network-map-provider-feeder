# ---- network-map-provider-feeder environment ----
# Neon Postgres connection string (same DB as Network Map)
DATABASE_URL=

# Disable scraper telemetry
DISABLE_TELEMETRY=1

# Worker tuning
MAX_JOBS_PER_LOOP=1
WORKER_POLL_INTERVAL_MS=30000
DEFAULT_CONCURRENCY=1

# Scraper
SCRAPER_IMAGE=gosom/google-maps-scraper
SCRAPER_TIMEOUT_MS=300000
