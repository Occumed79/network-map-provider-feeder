# Required
DATABASE_URL=

# Mapped-source feeder
FREE_ONLY_MODE=1
SCRAPER_PROVIDER=parallel_mapped_http
MAP_SOURCES=bing,google,apple
MAP_HTTP_TIMEOUT_MS=30000
MAX_RESULTS_PER_SOURCE=40
MAX_RESULTS_PER_JOB=120

# Worker loop
NODE_ENV=production
DISABLE_TELEMETRY=1
DEFAULT_CONCURRENCY=1
MAX_JOBS_PER_LOOP=1
SCRAPER_TIMEOUT_MS=300000

# Queue seeding
AUTO_SEED_ON_START=1
MIN_PENDING_JOBS=25
MAX_AUTO_SEED_JOBS=250

# Schema bootstrap and validation
ENABLE_SCHEMA_BOOTSTRAP=1
VALIDATE_SCHEMA_ON_START=1

# Job recovery
RESET_STALE_RUNNING_MINUTES=120

# Optional targeting filters
TARGET_STATES=
TARGET_CITIES=
TARGET_SERVICE_LINES=

# Seeded job defaults
DEFAULT_RADIUS_METERS=40000
DEFAULT_SCRAPER_DEPTH=1
DEFAULT_FAST_MODE=0

# Final app-facing provider output
ENABLE_APP_CANDIDATE_WRITE=1
APP_CANDIDATE_TABLE=provider_candidates

# Dashboard legacy separation
DASHBOARD_SHOW_LEGACY=0
