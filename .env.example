# ---- network-map-provider-feeder environment ----
# Neon Postgres connection string (same DB as Network Map)
DATABASE_URL=

# Source guardrail
FREE_ONLY_MODE=1
SCRAPER_PROVIDER=free_google_maps_scraper

# Scraper runtime
SCRAPER_MODE=binary
SCRAPER_BINARY=google-maps-scraper
SCRAPER_IMAGE=gosom/google-maps-scraper
SCRAPER_TIMEOUT_MS=300000
SCRAPER_EXIT_ON_INACTIVITY=3m
DISABLE_TELEMETRY=1

# Worker tuning
MAX_JOBS_PER_LOOP=1
WORKER_POLL_INTERVAL_MS=30000
DEFAULT_CONCURRENCY=1
RESET_STALE_RUNNING_MINUTES=120

# Startup behavior
VALIDATE_SCHEMA_ON_START=1
AUTO_SEED_ON_START=1
MIN_PENDING_JOBS=25
MAX_AUTO_SEED_JOBS=250
ALLOW_SCHEMA_CHANGES=0

# Targeted job generation
TARGET_STATES=
TARGET_CITIES=
TARGET_SERVICE_LINES=
DEFAULT_RADIUS_METERS=40000
DEFAULT_SCRAPER_DEPTH=1
DEFAULT_FAST_MODE=0
