# Required
DATABASE_URL=

# Runtime
NODE_ENV=production
DISABLE_TELEMETRY=1

# Render dashboard / schema guardrails
ENABLE_SCHEMA_BOOTSTRAP=1
VALIDATE_SCHEMA_ON_START=1
DASHBOARD_SHOW_LEGACY=0

# Scrapy crawler ingestion
SCRAPY_WRITE_TO_NEON=0

# Final app-facing provider output
ENABLE_APP_CANDIDATE_WRITE=1
APP_CANDIDATE_TABLE=provider_candidates
