# Database Configuration (Required)
DATABASE_URL=postgresql://user:password@host:port/database

# Scraper Configuration
SCRAPER_MODE=binary
SCRAPER_BINARY=google-maps-scraper
SCRAPER_TIMEOUT_MS=300000
DEFAULT_CONCURRENCY=1
MAX_JOBS_PER_LOOP=1

# Job Seeding
AUTO_SEED_ON_START=1
MIN_PENDING_JOBS=25
MAX_AUTO_SEED_JOBS=250

# Schema and Validation
VALIDATE_SCHEMA_ON_START=1
ALLOW_SCHEMA_CHANGES=0

# Job Recovery
RESET_STALE_RUNNING_MINUTES=120

# Targeting (optional - leave blank for all targets)
TARGET_STATES=
TARGET_CITIES=
TARGET_SERVICE_LINES=

# Default Job Parameters (used if columns exist in Neon)
DEFAULT_RADIUS_METERS=40000
DEFAULT_SCRAPER_DEPTH=1
DEFAULT_FAST_MODE=0

# Playwright Configuration
PLAYWRIGHT_BROWSERS_PATH=/opt/browsers
PLAYWRIGHT_DRIVER_PATH=/opt/ms-playwright-go/1.57.0
PLAYWRIGHT_NODEJS_PATH=/usr/bin/node

# Environment
NODE_ENV=production
DISABLE_TELEMETRY=1
